//@version=6
indicator("ETHUSDT - Didi + DMI + Fibo Realtime", overlay=true, calc_on_every_tick=true)

// ==================== INDICADORES ====================

// Didi Index (Médias Móveis)
shortMA = ta.sma(close, 3)
mediumMA = ta.sma(close, 8)
longMA = ta.sma(close, 20)

// DMI (Directional Movement Index)
[plusDI, minusDI, adx] = ta.dmi(14, 14)

// EMA 1h (aproximado usando EMA 50 no timeframe 15m)
ema_1h = ta.ema(close, 50)

// ATR (Average True Range)
atr = ta.atr(14)

// ==================== CONDIÇÕES DIDI ====================
didi_up = shortMA > mediumMA and mediumMA > longMA
didi_down = shortMA < mediumMA and mediumMA < longMA

// ==================== CONDIÇÕES DMI ====================
trend_up = plusDI > minusDI and adx > 25 and adx > adx[1]
trend_down = minusDI > plusDI and adx > 25 and adx > adx[1]

// ==================== CANDLE DE REFERÊNCIA ====================
// Busca o menor corpo real nas últimas 5 velas
var float ref_high = na
var float ref_low = na
var int ref_index = na

body_size_0 = math.abs(close - open)
body_size_1 = math.abs(close[1] - open[1])
body_size_2 = math.abs(close[2] - open[2])
body_size_3 = math.abs(close[3] - open[3])
body_size_4 = math.abs(close[4] - open[4])

min_body = math.min(body_size_0, body_size_1, body_size_2, body_size_3, body_size_4)

if body_size_0 == min_body
    ref_high := high
    ref_low := low
    ref_index := bar_index
else if body_size_1 == min_body
    ref_high := high[1]
    ref_low := low[1]
    ref_index := bar_index - 1
else if body_size_2 == min_body
    ref_high := high[2]
    ref_low := low[2]
    ref_index := bar_index - 2
else if body_size_3 == min_body
    ref_high := high[3]
    ref_low := low[3]
    ref_index := bar_index - 3
else
    ref_high := high[4]
    ref_low := low[4]
    ref_index := bar_index - 4

// ==================== DETECÇÃO DE ROMPIMENTO ====================
threshold = 0.0005 // 0.05%
buy_breakout = ta.crossover(close, ref_high * (1 + threshold))
sell_breakout = ta.crossunder(close, ref_low * (1 - threshold))

// ==================== FILTROS ADICIONAIS ====================
avg_volume = ta.sma(volume, 20)
volume_filter = volume > avg_volume

volatility_filter = atr > ta.sma(atr, 20) * 0.8

// ==================== SINAIS DE ENTRADA ====================
buy_signal = buy_breakout and didi_up and trend_up and close > ema_1h and volume_filter and volatility_filter
sell_signal = sell_breakout and didi_down and trend_down and close < ema_1h and volume_filter and volatility_filter

// ==================== FIBONACCI ORIENTADO PELA DIREÇÃO ====================
swingHigh = ta.highest(high, 20)
swingLow = ta.lowest(low, 20)

var float fib_0 = na
var float fib_382 = na
var float fib_618 = na
var float tp = na
var float sl = na
var string trade_direction = na

// COMPRA: Fibonacci de baixo para cima
if buy_signal
    fib_0 := swingLow
    fib_382 := fib_0 + (swingHigh - fib_0) * 0.382
    fib_618 := fib_0 + (swingHigh - fib_0) * 0.618
    tp := fib_618  // TP acima (projeção)
    sl := fib_382  // SL abaixo (retração)
    trade_direction := "BUY"

// VENDA: Fibonacci de cima para baixo
if sell_signal
    fib_0 := swingHigh
    fib_382 := fib_0 - (fib_0 - swingLow) * 0.382
    fib_618 := fib_0 - (fib_0 - swingLow) * 0.618
    tp := fib_618  // TP abaixo (projeção)
    sl := fib_382  // SL acima (retração)
    trade_direction := "SELL"

// ==================== VALIDAÇÃO DE RISCO-RETORNO ====================
rr_ratio = na(tp) or na(sl) ? 0.0 : math.abs(tp - close) / math.abs(sl - close)
valid_trade = rr_ratio >= 1.0  // Exige R:R >= 1:1

// ==================== PLOTAGEM ====================
// Médias Móveis Didi
plot(shortMA, color=color.new(color.green, 0), linewidth=1, title="SMA 3")
plot(mediumMA, color=color.new(color.yellow, 0), linewidth=1, title="SMA 8")
plot(longMA, color=color.new(color.red, 0), linewidth=1, title="SMA 20")

// EMA 1h
plot(ema_1h, color=color.new(color.blue, 0), linewidth=2, title="EMA 50 (1h aprox)")

// Níveis de referência
plot(ref_high, color=color.new(color.orange, 70), style=plot.style_linebr, linewidth=1, title="Ref High")
plot(ref_low, color=color.new(color.orange, 70), style=plot.style_linebr, linewidth=1, title="Ref Low")

// Fibonacci Levels
plot(not na(tp) ? tp : na, color=color.new(color.green, 0), linewidth=2, style=plot.style_cross, title="Take Profit")
plot(not na(sl) ? sl : na, color=color.new(color.red, 0), linewidth=2, style=plot.style_cross, title="Stop Loss")

// Sinais visuais
plotshape(buy_signal and valid_trade, style=shape.triangleup, location=location.belowbar, color=color.new(color.green, 0), size=size.normal, title="BUY Signal")
plotshape(sell_signal and valid_trade, style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.normal, title="SELL Signal")

// ==================== ALERTAS ====================
alertcondition(buy_signal and valid_trade, title="BUY Signal", message="🟢 Sinal de COMPRA confirmado (R:R >= 1:1)")
alertcondition(sell_signal and valid_trade, title="SELL Signal", message="🔴 Sinal de VENDA confirmado (R:R >= 1:1)")

// ==================== TABELA DE INFORMAÇÕES ====================
var table infoTable = table.new(position.top_right, 2, 8, border_width=1)

if barstate.islast
    table.cell(infoTable, 0, 0, "Indicador", bgcolor=color.new(color.gray, 70), text_color=color.white)
    table.cell(infoTable, 1, 0, "Valor", bgcolor=color.new(color.gray, 70), text_color=color.white)
    
    table.cell(infoTable, 0, 1, "ADX", text_color=color.white)
    table.cell(infoTable, 1, 1, str.tostring(adx, "#.##"), text_color=adx > 25 ? color.green : color.red)
    
    table.cell(infoTable, 0, 2, "+DI / -DI", text_color=color.white)
    table.cell(infoTable, 1, 2, str.tostring(plusDI, "#.#") + " / " + str.tostring(minusDI, "#.#"), text_color=color.white)
    
    table.cell(infoTable, 0, 3, "Didi", text_color=color.white)
    table.cell(infoTable, 1, 3, didi_up ? "ALTA" : didi_down ? "BAIXA" : "NEUTRO", text_color=didi_up ? color.green : didi_down ? color.red : color.gray)
    
    table.cell(infoTable, 0, 4, "R:R Ratio", text_color=color.white)
    table.cell(infoTable, 1, 4, str.tostring(rr_ratio, "#.##"), text_color=rr_ratio >= 1.0 ? color.green : color.red)
    
    table.cell(infoTable, 0, 5, "TP", text_color=color.white)
    table.cell(infoTable, 1, 5, not na(tp) ? str.tostring(tp, "#.##") : "-", text_color=color.green)
    
    table.cell(infoTable, 0, 6, "SL", text_color=color.white)
    table.cell(infoTable, 1, 6, not na(sl) ? str.tostring(sl, "#.##") : "-", text_color=color.red)
    
    table.cell(infoTable, 0, 7, "Status", text_color=color.white)
    table.cell(infoTable, 1, 7, valid_trade and (buy_signal or sell_signal) ? "SINAL VÁLIDO" : "AGUARDANDO", 
               text_color=valid_trade and (buy_signal or sell_signal) ? color.green : color.gray)
